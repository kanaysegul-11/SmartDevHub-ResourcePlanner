# Copy this file to `.env` and fill values for local development.
# Do NOT commit your real secrets. Add `.env` to .gitignore if needed.

# Frontend URL (where your app runs)
FRONTEND_APP_URL=http://localhost:5173

# Backend public URL (where GitHub should call webhooks)
BACKEND_PUBLIC_URL=http://localhost:8000

# GitHub OAuth
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret
GITHUB_OAUTH_SCOPES=read:user repo read:org admin:repo_hook
GITHUB_OAUTH_REDIRECT_URI=

# Webhook secret (choose a random string)
GITHUB_WEBHOOK_SECRET=choose_a_secret_here
GITHUB_WEBHOOK_TARGET_URL=
